SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InloYmtseHppa3RkcmFvdWV1bnh4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQzMTY2MjIsImV4cCI6MjA5OTg5MjYyMn0.pmryoWAa_ASJTgp7BEyTQKrD0PJGsNF0h4GCfMZLj0M

# ── Banco de Dados PostgreSQL (Supabase) ──────────────────
# Connection string do banco de dados
# A senha está no Supabase em: Project Settings > Database > Database password
DATABASE_URL=postgresql://postgres:[SUA-SENHA-DO-BANCO]@db.yhbklxziktdraoueunxx.supabase.co:5432/postgres

# ── Autenticação JWT ──────────────────────────────────────
# Segredo para assinar os tokens JWT da sessão (use uma string aleatória longa)
JWT_SECRET=seu-segredo-jwt-muito-longo-e-aleatorio-aqui

# ── Aplicação ─────────────────────────────────────────────
# ID único da aplicação
VITE_APP_ID=dev-ai-assistant

# OpenID do dono/admin da aplicação (ID do usuário no Supabase Auth)
# Encontre em: Supabase > Authentication > Users > copie o UUID do seu usuário
OWNER_OPEN_ID=

# ── LLM (Groq AI) ────────────────────────────────────────
# Chave da API do Groq (obtenha em https://console.groq.com/keys)
GROQ_API_KEY=sua-chave-groq-aqui
# GROQ_API_BASE=https://api.groq.com/openai/v1

# ── Auto-Melhoria ─────────────────────────────────────────
# Token do GitHub (para fazer push das melhorias)
# Gere em: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxx

# Chave secreta de aprovação (SÓ O DONO TEM)
# Qualquer pessoa pode sugerir melhorias, mas só quem tem essa chave pode aprovar
# Use uma string aleatória longa e segura
APPROVAL_KEY=sua-chave-secreta-aqui

# ── Ambiente ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
